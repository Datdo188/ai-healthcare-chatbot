APP_NAME=AI Healthcare Chatbot
APP_VERSION=1.0.0

# Local Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Local Ollama Embedding
OLLAMA_EMBED_URL=http://localhost:11434/api/embed
OLLAMA_EMBED_MODEL=nomic-embed-text

# Docker Ollama
# OLLAMA_URL=http://ollama:11434/api/generate
# OLLAMA_EMBED_URL=http://ollama:11434/api/embed

# Local PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_healthcare

# Docker PostgreSQL
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/ai_healthcare

SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

UPLOAD_DIR=data/medical_docs
MAX_UPLOAD_SIZE_MB=10

RAW_DOCS_DIR=data/raw

CHUNK_SIZE=800
CHUNK_OVERLAP=150

RAG_TOP_K=3
MIN_RELEVANCE_SCORE=0.25
MAX_CONTEXT_CHARS=6000

CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=medical_documents