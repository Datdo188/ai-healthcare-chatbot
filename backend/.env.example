APP_NAME=AI Healthcare Chatbot
APP_VERSION=1.0.0

# Local Ollama
OLLAMA_URL=http://localhost:11434/api/generate

# Docker Ollama
# OLLAMA_URL=http://ollama:11434/api/generate

OLLAMA_MODEL=llama3.1:8b

# Local PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_healthcare

# Docker PostgreSQL
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/ai_healthcare

SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OLLAMA_EMBED_URL=http://localhost:11434/api/embed
OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION_NAME=medical_documents